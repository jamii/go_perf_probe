uprobe:./main:runtime.itabAdd { 
    @typ[tid] = 18 // itab
}

uretprobe:./main:runtime.itabAdd { 
    delete(@typ[tid])
}

tracepoint:sched:sched_process_exit {
   if (@main_pid == pid) {
       exit();
   }
}

END {
    for ($typ_nameOff : @nameOff) {
        printf(
            "{\"TypePtr\": %lu, \"NameOff\": %u, \"Count\": %u}\n",
            $typ_nameOff.0,
            $typ_nameOff.1,
            @count[$typ_nameOff.0]
        ); 
    }
    clear(@main_pid);
    clear(@nameOff);
    clear(@count);
    clear(@typ);
}